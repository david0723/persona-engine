{
  "name": "persona-engine",
  "version": "0.1.0",
  "description": "Virtual persona engine - autonomous AI characters that live on your machine",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "persona": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:all": "vitest run && vitest run -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@opencode-ai/plugin": "^1.2.27",
    "@types/react": "^19.2.14",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
